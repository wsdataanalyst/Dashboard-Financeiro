# Ambiente virtual
venv/
env/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Banco de dados SQLite (contém dados reais - pode ser ignorado)
data/*.db
data/*.sqlite3
# Opcional: se quiser versionar um banco inicial vazio, remova a linha acima

# Arquivos de configuração de IDE
.vscode/
.idea/
*.swp
*.swo

# Sistema operacional
.DS_Store
Thumbs.db

# Logs
*.log

# Arquivos de upload (planilhas temporárias)
data/uploads/*
!data/uploads/.gitkeep

# Arquivos do Streamlit (cache)
.streamlit/secrets.toml